# Port the Express server listens on
PORT=3000

# Public HTTPS URL Crowdin will load this app from (e.g. your ngrok URL
# during development, or your production domain once deployed).
# This overrides manifest.json's baseUrl at request time so you don't
# have to hand-edit the file every time a tunnel URL changes.
PUBLIC_BASE_URL=https://your-tunnel-or-domain.example.com

# Upstash Redis (Console -> your database -> REST API section). Used for
# persistent storage of Crowdin OAuth installation credentials - see
# lib/store.js. Required in any deployment without a persistent local disk
# (which is most free hosting tiers, including Render's).
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Crowdin OAuth Application credentials (Organization Settings -> OAuth apps
# -> "Subtitle Video & Timing Editor" in the Sinch org). These are fixed,
# app-wide values - different from the per-installation appId/appSecret
# Crowdin POSTs to /hooks/installed. Required for the crowdin_app token
# exchange in lib/crowdinAuth.js.
CROWDIN_CLIENT_ID=your-oauth-app-client-id
CROWDIN_CLIENT_SECRET=your-oauth-app-client-secret
